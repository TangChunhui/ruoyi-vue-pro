#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/tang/Documents/GitHub/ruoyi-vue-pro/yudao-ui/yudao-ui-admin-vue3/node_modules/.pnpm/xml-js@1.6.11/node_modules/xml-js/node_modules:/Users/tang/Documents/GitHub/ruoyi-vue-pro/yudao-ui/yudao-ui-admin-vue3/node_modules/.pnpm/xml-js@1.6.11/node_modules:/Users/tang/Documents/GitHub/ruoyi-vue-pro/yudao-ui/yudao-ui-admin-vue3/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/tang/Documents/GitHub/ruoyi-vue-pro/yudao-ui/yudao-ui-admin-vue3/node_modules/.pnpm/xml-js@1.6.11/node_modules/xml-js/node_modules:/Users/tang/Documents/GitHub/ruoyi-vue-pro/yudao-ui/yudao-ui-admin-vue3/node_modules/.pnpm/xml-js@1.6.11/node_modules:/Users/tang/Documents/GitHub/ruoyi-vue-pro/yudao-ui/yudao-ui-admin-vue3/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../xml-js/bin/cli.js" "$@"
else
  exec node  "$basedir/../xml-js/bin/cli.js" "$@"
fi
